# GitHub personal access token (scope requis : repo)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub username/org to clone projects FROM
SOURCE_GITHUB_USER=my-username

# GitHub username/org to archive projects TO
DEST_GITHUB_ORG=my-archives-org

# Visibility of archived repos: public | private | mirror (default: mirror)
REPO_VISIBILITY=mirror
